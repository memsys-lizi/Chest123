{
  "name": "chest123-pan-sdk",
  "version": "0.1.5",
  "description": "Node.js SDK for 123Pan open platform APIs.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --exclude test/live.test.ts",
    "test:live": "vitest run test/live.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "123pan",
    "123yunpan",
    "sdk",
    "cloud-storage"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "1.15.2",
    "form-data": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "nock": "^13.5.6",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
